{
  "expo": {
    "name": "Horizon",
    "slug": "Harizana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/newIcon.png",
    "scheme": "horizon",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/newIcon.png",
      "supportsTablet": true
    },
    "android": {
      "package": "com.horizon.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/newIcon.png",
        "backgroundColor": "#C8E6FA"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/newIcon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Horizon needs access to your photos to set a profile picture.",
          "cameraPermission": "Horizon needs camera access to take a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C8E6FA",
          "image": "./assets/images/newIcon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/newIcon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Horizon needs your location to auto-fill your departure city."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Horizon needs camera access to scan driver QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/newIcon.png",
          "color": "#3B82F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "96f52c50-2ee0-4fc0-b8d1-98df36d375d9"
      }
    },
    "owner": "jawad_laghbar"
  }
}
